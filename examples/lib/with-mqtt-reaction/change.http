}

###

### Insert a new stock not present in bootstrap
POST http://localhost:9000/sources/stock-prices/events
Content-Type: application/json

{
  "operation": "insert",
  "element": {
    "type": "node",
    "id": "price_AMZN",
    "labels": ["stock_prices"],
    "properties": {
      "symbol": "AMZN",
      "price": 186.40,
      "previous_close": 182.10,
      "volume": 4400000
    }
  }
}

###

### Delete an existing bootstrap row
POST http://localhost:9000/sources/stock-prices/events
Content-Type: application/json

{
  "operation": "delete",
  "id": "price_MSFT",
  "labels": ["stock_prices"]
}

###

### Batch update using existing IDs from bootstrap
POST http://localhost:9000/sources/stock-prices/events/batch
Content-Type: application/json

{
  "events": [
    {
      "operation": "update",
      "element": {
        "type": "node",
        "id": "price_GOOGL",
        "labels": ["stock_prices"],
        "properties": {
          "symbol": "GOOGL",
          "price": 146.20,
          "previous_close": 140.50,
          "volume": 1800000
        }
      }
    },
    {
      "operation": "update",
      "element": {
        "type": "node",
        "id": "price_NVDA",
        "labels": ["stock_prices"],
        "properties": {
          "symbol": "NVDA",
          "price": 542.30,
          "previous_close": 515.00,
          "volume": 4600000
        }
      }
    }
  ]
}

